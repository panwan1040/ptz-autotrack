APP_CONFIG_PATH=configs/config.example.yaml
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_ENABLE_DEBUG_WINDOW=false
APP_ENABLE_OVERLAY=false
APP_ENABLE_API=true
APP_API_HOST=0.0.0.0
APP_API_PORT=8080
APP_METRICS_ENABLED=true
APP_DETECT_ONLY=false
APP_DRY_RUN_PTZ=true
APP_SAVE_ACTION_SCREENSHOTS=false
APP_SCREENSHOT_DIR=./artifacts/screenshots
APP_SNAPSHOT_DIR=./artifacts/snapshots
APP_MODEL_PATH=yolov8n.pt
APP_DEVICE=cpu
APP_HALF=false
APP_CONFIDENCE=0.45
APP_IOU=0.5
APP_IMGSZ=640
APP_CAMERA_HOST=192.168.1.100
APP_CAMERA_USERNAME=admin
APP_CAMERA_PASSWORD=change-me
APP_CAMERA_RTSP_PORT=554
APP_CAMERA_HTTP_PORT=80
APP_CAMERA_RTSP_PATH=/cam/realmonitor?channel=1&subtype=1
APP_CAMERA_CHANNEL=1
APP_CAMERA_TIMEOUT_SECONDS=3.0
APP_CAMERA_CONNECT_TIMEOUT_SECONDS=10.0
